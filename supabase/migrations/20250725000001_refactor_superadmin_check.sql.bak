-- Migration: 20250725000001_refactor_superadmin_check.sql
-- Description: 
-- 1. Refactors the is_super_admin() function to accept a user_id and use the user_assignments table for validation.
-- 2. Registers the disconnect_google_provider() function into the migration system and updates it to use the new is_super_admin(uuid) check.

-- Step 1: Drop the old is_super_admin function if it exists (it might not have a parameter)
DROP FUNCTION IF EXISTS public.is_super_admin();

-- Step 2: Create the new, refactored is_super_admin function that accepts a user_id
CREATE OR REPLACE FUNCTION public.is_super_admin(p_user_id UUID)
RETURNS BOOLEAN AS $$
DECLARE
    v_is_super BOOLEAN;
BEGIN
    -- Find the system owner tenant
    WITH owner_tenant AS (
        SELECT id FROM public.tenants WHERE is_system_owner = true LIMIT 1
    )
    -- Check if the user has the 'super_admin' role assigned for that tenant
    SELECT r.name = 'super_admin'
    INTO v_is_super
    FROM public.user_assignments ua
    JOIN public.roles r ON ua.role_id = r.id
    WHERE ua.user_id = p_user_id
      AND ua.tenant_id = (SELECT id FROM owner_tenant);

    -- Return true if found, false otherwise
    RETURN COALESCE(v_is_super, FALSE);
END;
$$ LANGUAGE plpgsql STABLE SECURITY DEFINER;

COMMENT ON FUNCTION public.is_super_admin(UUID) IS 'Checks if a user is a global super_admin by verifying their role assignment for the system owner tenant.';


-- Step 3: Create or replace the disconnect_google_provider function to register it and use the new validation
CREATE OR REPLACE FUNCTION public.disconnect_google_provider(p_tenant_id uuid, p_provider text, p_requesting_user_id uuid)
RETURNS json
LANGUAGE plpgsql
SECURITY DEFINER
AS $function$
BEGIN
    -- Step 1: Validate permissions using the new refactored function
    IF NOT public.is_super_admin(p_requesting_user_id) THEN
        RETURN json_build_object('success', false, 'message', 'Acceso no autorizado. Se requiere ser superadministrador.');
    END IF;

    -- Step 2: Proceed with deleting the specific integration for the given tenant.
    DELETE FROM public.tenant_integrations
    WHERE tenant_id = p_tenant_id AND provider = p_provider;

    -- The 'FOUND' variable in PL/pgSQL is true if the last operation (DELETE) affected at least one row.
    IF FOUND THEN
        RETURN json_build_object('success', true, 'message', 'Integración desconectada correctamente.');
    ELSE
        -- If no row was found to delete, inform that it didn't exist.
        RETURN json_build_object('success', false, 'message', 'No se encontró una integración activa de este tipo para el tenant especificado.');
    END IF;

EXCEPTION
    -- Catch any other errors that might occur during execution.
    WHEN OTHERS THEN
        RETURN json_build_object('success', false, 'message', 'Ocurrió un error interno al intentar desconectar la integración: ' || SQLERRM);
END;
$function$;

COMMENT ON FUNCTION public.disconnect_google_provider(uuid, text, uuid) IS 'Allows a super_admin to disconnect a Google integration for a specific tenant.';

